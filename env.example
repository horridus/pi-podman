# Copia questo file in .env e imposta il percorso ASSOLUTO della cartella che vuoi montare
PIPODMAN_WORKSPACE_PATH=/home/tuoutente/progetti/mio-progetto

# Percorso della cartella di configurazione di pi sull'host (opzionale, default: ~/.pi)
PI_CONFIG_PATH=~/.pi

# Percorso della cartella delle estensioni custom
PI_CUSTOM_EXTENSIONS_PATH=~/workspace/ia/pi-horridus

# Configurazione MariaDB
MARIADB_DATABASE=pi
MARIADB_USER=pi
MARIADB_PASSWORD=CHANGE_ME_STRONG_USER_PASSWORD
MARIADB_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD