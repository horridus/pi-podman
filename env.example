# Copia questo file in .env e imposta il percorso ASSOLUTO della cartella che vuoi montare
WORKSPACE_PATH=/home/tuoutente/progetti/mio-progetto

# --- Ollama ---
OLLAMA_BASE_URL=http://192.168.0.188:11434
OLLAMA_MODEL=qwen2.5-coder:32b

# --- llama.cpp (alternativa a Ollama, commenta le righe Ollama sopra se usi questo) ---
# LLAMACPP_BASE_URL=http://192.168.0.188:8080
# LLAMACPP_MODEL=qwen2.5-coder   # nome libero, usato solo internamente da pi

# Percorso della cartella di configurazione di pi sull'host (opzionale, default: ~/.pi)
PI_CONFIG_PATH=~/.pi
